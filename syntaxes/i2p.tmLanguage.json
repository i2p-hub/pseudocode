{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/refs/heads/master/tmlanguage.json",
  "name": "Pseudocode",
  "scopeName": "source.pseudocode",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#placeholders"
    },
    {
      "include": "#statements"
    },
    {
      "include": "#boolean-literal"
    },
    {
      "include": "#numeric-literal"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#delimiters"
    },
    {
      "include": "#fallback-keywords"
    },
    {
      "include": "#identifiers"
    }
  ],
  "repository": {
    "statements": {
      "patterns": [
        {
          "include": "#program-terminators"
        },
        {
          "include": "#input-statements"
        },
        {
          "include": "#output-statements"
        },
        {
          "include": "#assignment-statements"
        },
        {
          "include": "#call-statements"
        },
        {
          "include": "#conditional-statements"
        },
        {
          "include": "#loop-statements"
        },
        {
          "include": "#standalone-keywords"
        }
      ]
    },

    "expression-patterns": {
      "patterns": [
        {
          "include": "#comments"
        },
        {
          "include": "#strings"
        },
        {
          "include": "#placeholders"
        },
        {
          "include": "#boolean-literal"
        },
        {
          "include": "#numeric-literal"
        },
        {
          "include": "#operators"
        },
        {
          "include": "#delimiters"
        },
        {
          "include": "#fallback-keywords"
        },
        {
          "include": "#identifiers"
        }
      ]
    },

    "fallback-keywords": {
      "patterns": [
        {
          "name": "keyword.control",
          "match": "\\b(?:START|END|GET|PUT|LET|CALL|IF|ELSEIF|ELSE|ENDIF|WHILE|DO|ENDWHILE|FOR|FOREACH|ENDFOR|FROM|TO|STEP|IN)\\b"
        },
        {
          "name": "keyword.operator.logical",
          "match": "\\b(?:AND|OR|NOT)\\b"
        }
      ]
    },

    "program-terminators": {
      "patterns": [
        {
          "name": "meta.program.start.pseudocode",
          "match": "^\\s*(START)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*(#.*)?$",
          "captures": {
            "1": {
              "name": "keyword.control"
            },
            "2": {
              "name": "entity.name.function"
            },
            "3": {
              "name": "comment.line.number-sign"
            }
          }
        },
        {
          "name": "meta.program.end.pseudocode",
          "match": "^\\s*(END)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*(#.*)?$",
          "captures": {
            "1": {
              "name": "keyword.control"
            },
            "2": {
              "name": "entity.name.function"
            },
            "3": {
              "name": "comment.line.number-sign"
            }
          }
        }
      ]
    },

    "input-statements": {
      "patterns": [
        {
          "name": "meta.input.statement.pseudocode",
          "begin": "^\\s*(GET)\\s+([A-Z][A-Za-z0-9]*(?:_[A-Z][A-Za-z0-9]*)+)",
          "beginCaptures": {
            "1": {
              "name": "keyword.control"
            },
            "2": {
              "name": "constant.language"
            }
          },
          "end": "(?=#|$)",
          "patterns": [
            {
              "match": "\\bFROM\\b",
              "name": "keyword.control"
            },
            {
              "include": "#expression-patterns"
            }
          ]
        },
        {
          "name": "meta.input.statement.pseudocode",
          "begin": "^\\s*(GET)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "beginCaptures": {
            "1": {
              "name": "keyword.control"
            },
            "2": {
              "name": "variable.other"
            }
          },
          "end": "(?=#|$)",
          "patterns": [
            {
              "match": "\\bFROM\\b",
              "name": "keyword.control"
            },
            {
              "include": "#expression-patterns"
            }
          ]
        }
      ]
    },

    "output-statements": {
      "patterns": [
        {
          "name": "meta.output.statement.pseudocode",
          "begin": "^\\s*(PUT)\\b",
          "beginCaptures": {
            "1": {
              "name": "keyword.control"
            }
          },
          "end": "(?=#|$)",
          "contentName": "meta.output.expression.pseudocode",
          "patterns": [
            {
              "match": "\\bTO\\b",
              "name": "keyword.control"
            },
            {
              "include": "#expression-patterns"
            }
          ]
        }
      ]
    },

    "assignment-statements": {
      "patterns": [
        {
          "name": "meta.assignment.statement.pseudocode",
          "begin": "^\\s*(LET)\\s+([A-Z][A-Za-z0-9]*(?:_[A-Z][A-Za-z0-9]*)+)\\s*(=)",
          "beginCaptures": {
            "1": {
              "name": "keyword.control"
            },
            "2": {
              "name": "constant.language"
            },
            "3": {
              "name": "keyword.operator"
            }
          },
          "end": "(?=#|$)",
          "contentName": "meta.assignment.expression.pseudocode",
          "patterns": [
            {
              "include": "#expression-patterns"
            }
          ]
        },
        {
          "name": "meta.assignment.statement.pseudocode",
          "begin": "^\\s*(LET)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*(=)",
          "beginCaptures": {
            "1": {
              "name": "keyword.control"
            },
            "2": {
              "name": "variable.other"
            },
            "3": {
              "name": "keyword.operator"
            }
          },
          "end": "(?=#|$)",
          "contentName": "meta.assignment.expression.pseudocode",
          "patterns": [
            {
              "include": "#expression-patterns"
            }
          ]
        }
      ]
    },

    "call-statements": {
      "patterns": [
        {
          "name": "meta.call.statement.pseudocode",
          "begin": "^\\s*(CALL)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*(\\()",
          "beginCaptures": {
            "1": {
              "name": "keyword.control"
            },
            "2": {
              "name": "entity.name.function"
            },
            "3": {
              "name": "punctuation.section.group.begin"
            }
          },
          "end": "(\\))(?=\\s*(#|$))",
          "endCaptures": {
            "1": {
              "name": "punctuation.section.group.end"
            }
          },
          "patterns": [
            {
              "name": "punctuation.separator",
              "match": ","
            },
            {
              "include": "#expression-patterns"
            }
          ]
        },
        {
          "name": "meta.call.statement.noargs.pseudocode",
          "match": "^\\s*(CALL)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*(#.*)?$",
          "captures": {
            "1": {
              "name": "keyword.control"
            },
            "2": {
              "name": "entity.name.function"
            },
            "3": {
              "name": "comment.line.number-sign"
            }
          }
        }
      ]
    },

    "conditional-statements": {
      "patterns": [
        {
          "name": "meta.conditional.if.pseudocode",
          "begin": "^\\s*(IF)\\b",
          "beginCaptures": {
            "1": {
              "name": "keyword.control"
            }
          },
          "end": "(?=#|$)",
          "contentName": "meta.condition.expression.pseudocode",
          "patterns": [
            {
              "include": "#expression-patterns"
            }
          ]
        },
        {
          "name": "meta.conditional.elseif.pseudocode",
          "begin": "^\\s*(ELSEIF)\\b",
          "beginCaptures": {
            "1": {
              "name": "keyword.control"
            }
          },
          "end": "(?=#|$)",
          "contentName": "meta.condition.expression.pseudocode",
          "patterns": [
            {
              "include": "#expression-patterns"
            }
          ]
        },
        {
          "name": "meta.conditional.else.pseudocode",
          "match": "^\\s*(ELSE)\\s*(#.*)?$",
          "captures": {
            "1": {
              "name": "keyword.control"
            },
            "2": {
              "name": "comment.line.number-sign"
            }
          }
        },
        {
          "name": "meta.conditional.endif.pseudocode",
          "match": "^\\s*(ENDIF)\\s*(#.*)?$",
          "captures": {
            "1": {
              "name": "keyword.control"
            },
            "2": {
              "name": "comment.line.number-sign"
            }
          }
        }
      ]
    },

    "loop-statements": {
      "patterns": [
        {
          "name": "meta.loop.while.pseudocode",
          "begin": "^\\s*(WHILE)\\b",
          "beginCaptures": {
            "1": {
              "name": "keyword.control"
            }
          },
          "end": "(?=#|$)",
          "patterns": [
            {
              "match": "\\bDO\\b",
              "name": "keyword.control"
            },
            {
              "include": "#expression-patterns"
            }
          ]
        },
        {
          "name": "meta.loop.do-while.pseudocode",
          "begin": "^\\s*(DO)\\s*(?:\\.\\.\\.\\s*)?(WHILE)\\b",
          "beginCaptures": {
            "1": {
              "name": "keyword.control"
            },
            "2": {
              "name": "keyword.control"
            }
          },
          "end": "(?=#|$)",
          "contentName": "meta.condition.expression.pseudocode",
          "patterns": [
            {
              "include": "#expression-patterns"
            }
          ]
        },
        {
          "name": "meta.loop.do.pseudocode",
          "match": "^\\s*(DO)\\s*(#.*)?$",
          "captures": {
            "1": {
              "name": "keyword.control"
            },
            "2": {
              "name": "comment.line.number-sign"
            }
          }
        },
        {
          "name": "meta.loop.endwhile.pseudocode",
          "match": "^\\s*(ENDWHILE)\\s*(#.*)?$",
          "captures": {
            "1": {
              "name": "keyword.control"
            },
            "2": {
              "name": "comment.line.number-sign"
            }
          }
        },
        {
          "name": "meta.loop.for.pseudocode",
          "begin": "^\\s*(FOR)\\s+([A-Z][A-Za-z0-9]*(?:_[A-Z][A-Za-z0-9]*)+)\\s*(=)",
          "beginCaptures": {
            "1": {
              "name": "keyword.control"
            },
            "2": {
              "name": "constant.language"
            },
            "3": {
              "name": "keyword.operator"
            }
          },
          "end": "(?=#|$)",
          "patterns": [
            {
              "match": "\\b(?:TO|STEP)\\b",
              "name": "keyword.control"
            },
            {
              "include": "#expression-patterns"
            }
          ]
        },
        {
          "name": "meta.loop.for.pseudocode",
          "begin": "^\\s*(FOR)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*(=)",
          "beginCaptures": {
            "1": {
              "name": "keyword.control"
            },
            "2": {
              "name": "variable.other"
            },
            "3": {
              "name": "keyword.operator"
            }
          },
          "end": "(?=#|$)",
          "patterns": [
            {
              "match": "\\b(?:TO|STEP)\\b",
              "name": "keyword.control"
            },
            {
              "include": "#expression-patterns"
            }
          ]
        },
        {
          "name": "meta.loop.foreach.pseudocode",
          "begin": "^\\s*(FOREACH)\\s+([A-Z][A-Za-z0-9]*(?:_[A-Z][A-Za-z0-9]*)+)\\s+(IN)\\b",
          "beginCaptures": {
            "1": {
              "name": "keyword.control"
            },
            "2": {
              "name": "constant.language"
            },
            "3": {
              "name": "keyword.control"
            }
          },
          "end": "(?=#|$)",
          "contentName": "meta.loop.collection.pseudocode",
          "patterns": [
            {
              "include": "#expression-patterns"
            }
          ]
        },
        {
          "name": "meta.loop.foreach.pseudocode",
          "begin": "^\\s*(FOREACH)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s+(IN)\\b",
          "beginCaptures": {
            "1": {
              "name": "keyword.control"
            },
            "2": {
              "name": "variable.other"
            },
            "3": {
              "name": "keyword.control"
            }
          },
          "end": "(?=#|$)",
          "contentName": "meta.loop.collection.pseudocode",
          "patterns": [
            {
              "include": "#expression-patterns"
            }
          ]
        },
        {
          "name": "meta.loop.endfor.pseudocode",
          "match": "^\\s*(ENDFOR)\\s*(#.*)?$",
          "captures": {
            "1": {
              "name": "keyword.control"
            },
            "2": {
              "name": "comment.line.number-sign"
            }
          }
        }
      ]
    },

    "standalone-keywords": {
      "patterns": [
        {
          "name": "keyword.operator.logical",
          "match": "\\b(?:AND|OR|NOT)\\b"
        },
        {
          "name": "keyword.control",
          "match": "\\b(?:FROM|TO)\\b"
        },
        {
          "name": "keyword.control",
          "match": "\\b(?:STEP|IN|DO)\\b"
        }
      ]
    },

    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign",
          "begin": "#",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.comment"
            }
          },
          "end": "$"
        }
      ]
    },

    "strings": {
      "patterns": [
        {
          "name": "string.quoted.multi.pseudocode",
          "begin": "\"\"\"",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.string.begin"
            }
          },
          "end": "\"\"\"",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.string.end"
            }
          },
          "patterns": [
            {
              "name": "constant.character.escape",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.double",
          "begin": "\"",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.string.begin"
            }
          },
          "end": "\"",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.string.end"
            }
          },
          "patterns": [
            {
              "name": "constant.character.escape",
              "match": "\\\\."
            }
          ]
        }
      ]
    },

    "placeholders": {
      "patterns": [
        {
          "name": "meta.placeholder.pseudocode",
          "match": "<[^>]+>"
        }
      ]
    },

    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arithmetic",
          "match": "\\*\\*"
        },
        {
          "name": "keyword.operator.arithmetic",
          "match": "//"
        },
        {
          "name": "keyword.operator.comparison",
          "match": "(==|!=|>=|<=|>|<)"
        },
        {
          "name": "keyword.operator",
          "match": "="
        },
        {
          "name": "keyword.operator",
          "match": "&"
        },
        {
          "name": "keyword.operator.arithmetic",
          "match": "(\\+|-|\\*|/|%)"
        }
      ]
    },

    "delimiters": {
      "patterns": [
        {
          "name": "punctuation.separator",
          "match": ","
        },
        {
          "name": "punctuation.separator",
          "match": ":"
        },
        {
          "name": "punctuation.section.group.begin",
          "match": "\\("
        },
        {
          "name": "punctuation.section.group.end",
          "match": "\\)"
        },
        {
          "name": "punctuation.section.array.begin",
          "match": "\\["
        },
        {
          "name": "punctuation.section.array.end",
          "match": "\\]"
        },
        {
          "name": "punctuation.section.block.begin",
          "match": "\\{"
        },
        {
          "name": "punctuation.section.block.end",
          "match": "\\}"
        }
      ]
    },

    "identifiers": {
      "patterns": [
        {
          "name": "constant.language",
          "match": "\\b[A-Z][A-Za-z0-9]*(?:_[A-Z][A-Za-z0-9]*)+\\b"
        },
        {
          "name": "variable.other",
          "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b"
        }
      ]
    },

    "numeric-literal": {
      "patterns": [
        {
          "name": "constant.numeric",
          "match": "(?<![A-Za-z0-9_])-?(?:0|[1-9][0-9_]*)\\.[0-9][0-9_]*(?![A-Za-z0-9_])"
        },
        {
          "name": "constant.numeric",
          "match": "(?<![A-Za-z0-9_])-?(?:0|[1-9][0-9_]*)(?![A-Za-z0-9_])"
        }
      ]
    },

    "boolean-literal": {
      "patterns": [
        {
          "name": "constant.language.boolean",
          "match": "\\bTrue\\b"
        },
        {
          "name": "constant.language.boolean",
          "match": "\\bFalse\\b"
        }
      ]
    }
  }
}