{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/refs/heads/master/tmlanguage.json",
  "name": "Pseudocode",
  "scopeName": "source.pseudocode",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#placeholders"
    },
    {
      "include": "#statements"
    },
    {
      "include": "#boolean-literal"
    },
    {
      "include": "#numeric-literal"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#delimiters"
    },
    {
      "include": "#identifiers"
    }
  ],
  "repository": {
    "statements": {
      "patterns": [
        {
          "include": "#program-terminators"
        },
        {
          "include": "#input-statements"
        },
        {
          "include": "#output-statements"
        },
        {
          "include": "#assignment-statements"
        },
        {
          "include": "#call-statements"
        },
        {
          "include": "#conditional-statements"
        },
        {
          "include": "#loop-statements"
        },
        {
          "include": "#standalone-keywords"
        }
      ]
    },

    "expression-patterns": {
      "patterns": [
        {
          "include": "#strings"
        },
        {
          "include": "#placeholders"
        },
        {
          "include": "#boolean-literal"
        },
        {
          "include": "#numeric-literal"
        },
        {
          "include": "#operators"
        },
        {
          "include": "#delimiters"
        },
        {
          "include": "#identifiers"
        }
      ]
    },

    "program-terminators": {
      "patterns": [
        {
          "name": "meta.program.start.pseudocode",
          "match": "^\\s*(START)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*$",
          "captures": {
            "1": {
              "name": "keyword.control.terminator.pseudocode"
            },
            "2": {
              "name": "entity.name.function.pseudocode"
            }
          }
        },
        {
          "name": "meta.program.end.pseudocode",
          "match": "^\\s*(END)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*$",
          "captures": {
            "1": {
              "name": "keyword.control.terminator.pseudocode"
            },
            "2": {
              "name": "entity.name.function.pseudocode"
            }
          }
        }
      ]
    },

    "input-statements": {
      "patterns": [
        {
          "name": "meta.input.statement.pseudocode",
          "begin": "^\\s*(GET)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "beginCaptures": {
            "1": {
              "name": "keyword.control.io.pseudocode"
            },
            "2": {
              "name": "variable.other.readwrite.pseudocode"
            }
          },
          "end": "\\s*$",
          "patterns": [
            {
              "match": "\\b(FROM)\\b",
              "captures": {
                "1": {
                  "name": "keyword.control.io.pseudocode"
                }
              }
            },
            {
              "include": "#expression-patterns"
            }
          ]
        }
      ]
    },

    "output-statements": {
      "patterns": [
        {
          "name": "meta.output.statement.pseudocode",
          "begin": "^\\s*(PUT)\\b",
          "beginCaptures": {
            "1": {
              "name": "keyword.control.io.pseudocode"
            }
          },
          "end": "\\s*$",
          "contentName": "meta.output.expression.pseudocode",
          "patterns": [
            {
              "match": "\\b(TO)\\b",
              "captures": {
                "1": {
                  "name": "keyword.control.io.pseudocode"
                }
              }
            },
            {
              "include": "#expression-patterns"
            }
          ]
        }
      ]
    },

    "assignment-statements": {
      "patterns": [
        {
          "name": "meta.assignment.statement.pseudocode",
          "begin": "^\\s*(LET)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*(=)",
          "beginCaptures": {
            "1": {
              "name": "keyword.control.assignment.pseudocode"
            },
            "2": {
              "name": "variable.other.assignment.pseudocode"
            },
            "3": {
              "name": "keyword.operator.assignment.pseudocode"
            }
          },
          "end": "\\s*$",
          "contentName": "meta.assignment.expression.pseudocode",
          "patterns": [
            {
              "include": "#expression-patterns"
            }
          ]
        }
      ]
    },

    "call-statements": {
      "patterns": [
        {
          "name": "meta.call.statement.pseudocode",
          "begin": "^\\s*(CALL)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*(\\()",
          "beginCaptures": {
            "1": {
              "name": "keyword.control.call.pseudocode"
            },
            "2": {
              "name": "entity.name.function.pseudocode"
            },
            "3": {
              "name": "punctuation.section.group.begin.pseudocode"
            }
          },
          "end": "(\\))\\s*$",
          "endCaptures": {
            "1": {
              "name": "punctuation.section.group.end.pseudocode"
            }
          },
          "patterns": [
            {
              "name": "punctuation.separator.arguments.pseudocode",
              "match": ","
            },
            {
              "include": "#expression-patterns"
            }
          ]
        },
        {
          "name": "meta.call.statement.noargs.pseudocode",
          "match": "^\\s*(CALL)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*$",
          "captures": {
            "1": {
              "name": "keyword.control.call.pseudocode"
            },
            "2": {
              "name": "entity.name.function.pseudocode"
            }
          }
        }
      ]
    },

    "conditional-statements": {
      "patterns": [
        {
          "name": "meta.conditional.if.pseudocode",
          "begin": "^\\s*(IF)\\b",
          "beginCaptures": {
            "1": {
              "name": "keyword.control.conditional.pseudocode"
            }
          },
          "end": "\\s*$",
          "contentName": "meta.condition.expression.pseudocode",
          "patterns": [
            {
              "include": "#expression-patterns"
            }
          ]
        },
        {
          "name": "meta.conditional.elseif.pseudocode",
          "begin": "^\\s*(ELSEIF)\\b",
          "beginCaptures": {
            "1": {
              "name": "keyword.control.conditional.pseudocode"
            }
          },
          "end": "\\s*$",
          "contentName": "meta.condition.expression.pseudocode",
          "patterns": [
            {
              "include": "#expression-patterns"
            }
          ]
        },
        {
          "name": "meta.conditional.else.pseudocode",
          "match": "^\\s*(ELSE)\\s*$",
          "captures": {
            "1": {
              "name": "keyword.control.conditional.pseudocode"
            }
          }
        },
        {
          "name": "meta.conditional.endif.pseudocode",
          "match": "^\\s*(ENDIF)\\s*$",
          "captures": {
            "1": {
              "name": "keyword.control.conditional.pseudocode"
            }
          }
        }
      ]
    },

    "loop-statements": {
      "patterns": [
        {
          "name": "meta.loop.while.pseudocode",
          "begin": "^\\s*(WHILE)\\b",
          "beginCaptures": {
            "1": {
              "name": "keyword.control.loop.pseudocode"
            }
          },
          "end": "\\s*$",
          "patterns": [
            {
              "match": "\\b(DO)\\b",
              "captures": {
                "1": {
                  "name": "keyword.control.loop.pseudocode"
                }
              }
            },
            {
              "include": "#expression-patterns"
            }
          ]
        },
        {
          "name": "meta.loop.do-while.pseudocode",
          "begin": "^\\s*(DO)\\s*(?:\\.\\.\\.\\s*)?(WHILE)\\b",
          "beginCaptures": {
            "1": {
              "name": "keyword.control.loop.pseudocode"
            },
            "2": {
              "name": "keyword.control.loop.pseudocode"
            }
          },
          "end": "\\s*$",
          "contentName": "meta.condition.expression.pseudocode",
          "patterns": [
            {
              "include": "#expression-patterns"
            }
          ]
        },
        {
          "name": "meta.loop.do.pseudocode",
          "match": "^\\s*(DO)\\s*$",
          "captures": {
            "1": {
              "name": "keyword.control.loop.pseudocode"
            }
          }
        },
        {
          "name": "meta.loop.endwhile.pseudocode",
          "match": "^\\s*(ENDWHILE)\\s*$",
          "captures": {
            "1": {
              "name": "keyword.control.loop.pseudocode"
            }
          }
        },
        {
          "name": "meta.loop.for.pseudocode",
          "begin": "^\\s*(FOR)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*(=)",
          "beginCaptures": {
            "1": {
              "name": "keyword.control.loop.pseudocode"
            },
            "2": {
              "name": "variable.other.assignment.pseudocode"
            },
            "3": {
              "name": "keyword.operator.assignment.pseudocode"
            }
          },
          "end": "\\s*$",
          "patterns": [
            {
              "match": "\\b(TO|STEP)\\b",
              "captures": {
                "1": {
                  "name": "keyword.control.loop.pseudocode"
                }
              }
            },
            {
              "include": "#expression-patterns"
            }
          ]
        },
        {
          "name": "meta.loop.foreach.pseudocode",
          "begin": "^\\s*(FOREACH)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s+(IN)\\b",
          "beginCaptures": {
            "1": {
              "name": "keyword.control.loop.pseudocode"
            },
            "2": {
              "name": "variable.other.assignment.pseudocode"
            },
            "3": {
              "name": "keyword.control.loop.pseudocode"
            }
          },
          "end": "\\s*$",
          "contentName": "meta.loop.collection.pseudocode",
          "patterns": [
            {
              "include": "#expression-patterns"
            }
          ]
        },
        {
          "name": "meta.loop.endfor.pseudocode",
          "match": "^\\s*(ENDFOR)\\s*$",
          "captures": {
            "1": {
              "name": "keyword.control.loop.pseudocode"
            }
          }
        }
      ]
    },

    "standalone-keywords": {
      "patterns": [
        {
          "name": "keyword.operator.logical",
          "match": "\\b(?:AND|OR|NOT)\\b"
        },
        {
          "name": "keyword.control.io.pseudocode",
          "match": "\\b(?:FROM|TO)\\b"
        },
        {
          "name": "keyword.control.loop.pseudocode",
          "match": "\\b(?:STEP|IN|DO)\\b"
        }
      ]
    },

    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.pseudocode",
          "begin": "(^[ \\t]+)?(#)",
          "beginCaptures": {
            "1": {
              "name": "punctuation.whitespace.comment.leading.pseudocode"
            },
            "2": {
              "name": "punctuation.definition.comment.pseudocode"
            }
          },
          "end": "(?=$)"
        }
      ]
    },

    "strings": {
      "name": "string.quoted.double.pseudocode",
      "begin": "\"",
      "beginCaptures": {
        "0": {
          "name": "punctuation.definition.string.begin.pseudocode"
        }
      },
      "end": "\"",
      "endCaptures": {
        "0": {
          "name": "punctuation.definition.string.end.pseudocode"
        }
      },
      "patterns": [
        {
          "name": "constant.character.escape.pseudocode",
          "match": "\\\\."
        }
      ]
    },

    "placeholders": {
      "patterns": [
        {
          "name": "meta.placeholder.pseudocode",
          "match": "<[^>]+>"
        }
      ]
    },

    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arithmetic.exponent.pseudocode",
          "match": "\\*\\*"
        },
        {
          "name": "keyword.operator.arithmetic.integer-division.pseudocode",
          "match": "//"
        },
        {
          "name": "keyword.operator.comparison.pseudocode",
          "match": "(==|!=|>=|<=|>|<)"
        },
        {
          "name": "keyword.operator.assignment.pseudocode",
          "match": "="
        },
        {
          "name": "keyword.operator.concatenation.pseudocode",
          "match": "&"
        },
        {
          "name": "keyword.operator.arithmetic.pseudocode",
          "match": "(\\+|-|\\*|/|%)"
        }
      ]
    },

    "delimiters": {
      "patterns": [
        {
          "name": "punctuation.separator.delimiter.pseudocode",
          "match": ","
        },
        {
          "name": "punctuation.separator.key-value.pseudocode",
          "match": ":"
        },
        {
          "name": "punctuation.section.group.begin.pseudocode",
          "match": "\\("
        },
        {
          "name": "punctuation.section.group.end.pseudocode",
          "match": "\\)"
        },
        {
          "name": "punctuation.section.array.begin.pseudocode",
          "match": "\\["
        },
        {
          "name": "punctuation.section.array.end.pseudocode",
          "match": "\\]"
        },
        {
          "name": "punctuation.section.map.begin.pseudocode",
          "match": "\\{"
        },
        {
          "name": "punctuation.section.map.end.pseudocode",
          "match": "\\}"
        }
      ]
    },

    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.pseudocode",
          "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b"
        }
      ]
    },

    "numeric-literal": {
      "patterns": [
        {
          "name": "constant.numeric.real.pseudocode",
          "match": "(?<![A-Za-z0-9_])-?(?:0|[1-9][0-9_]*)\\.[0-9][0-9_]*(?![A-Za-z0-9_])"
        },
        {
          "name": "constant.numeric.integer.pseudocode",
          "match": "(?<![A-Za-z0-9_])-?(?:0|[1-9][0-9_]*)(?![A-Za-z0-9_])"
        }
      ]
    },

    "boolean-literal": {
      "patterns": [
        {
          "name": "constant.language.boolean.true.pseudocode",
          "match": "\\bTrue\\b"
        },
        {
          "name": "constant.language.boolean.false.pseudocode",
          "match": "\\bFalse\\b"
        }
      ]
    }
  }
}